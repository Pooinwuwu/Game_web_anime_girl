@model dynamic
@{
    Layout = "_Layout"; // ใช้ Layout หลักของเว็บ
    ViewData["Title"] = "Anime Girl Battle";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

<style>
    .char-card {
        transition: transform 0.3s;
        cursor: pointer;
    }

        .char-card:hover {
            transform: scale(1.05); /* ขยายขนาดเวลาเอาเมาส์ไปชี้ */
        }

    .char-img {
        width: 100%;
        height: 450px;
        object-fit: cover;
        border-radius: 15px;
    }
</style>

<div class="container text-center mt-5">
    <h1 class="display-4 mb-5 animate__animated animate__fadeInDown">เลือกคนที่คุณชอบที่สุด!</h1>

    <div class="row">
        <div class="col-md-6 animate__animated animate__fadeInLeft">
            <form asp-controller="BackHome" asp-action="Vote" method="post">
                <input type="hidden" name="winnerId" value="@ViewBag.Char1.Id" />
                <button type="submit" class="btn p-0 border-0 char-card shadow-lg bg-white rounded">
                    <img src="@ViewBag.Char1.ImageUrl" class="char-img">
                    <div class="p-3">
                        <h2>@ViewBag.Char1.Name</h2>
                    </div>
                </button>
            </form>
        </div>

        <div class="col-md-6 animate__animated animate__fadeInRight">
            <form asp-controller="BackHome" asp-action="Vote" method="post">
                <input type="hidden" name="winnerId" value="@ViewBag.Char2.Id" />
                <button type="submit" class="btn p-0 border-0 char-card shadow-lg bg-white rounded">
                    <img src="@ViewBag.Char2.ImageUrl" class="char-img">
                    <div class="p-3">
                        <h2>@ViewBag.Char2.Name</h2>
                    </div>
                </button>
            </form>
        </div>
    </div>
</div>